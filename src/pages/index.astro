---
import { getCollection } from 'astro:content';
import BlogCard from '../components/react/BlogCard.tsx';
import ProjectCard from '../components/react/ProjectCard.tsx';
import SectionHeading from '../components/react/SectionHeading.tsx';
import "../styles/global.css";
import BaseLayout from '@/layouts/BaseLayout.astro';

const projects = (await getCollection('projects')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const recentPosts = posts.slice(0, 3);
const featuredProjects = projects.slice(0, 3);
---

<BaseLayout description="Irham's personal website where he shares his journey as a software engineer, focusing on frontend development, design systems, and user experience." title="Irham's Personal Website">
  <main class="flex-1">
    <section class="container py-20 md:py-28">
      <div class="max-w-2xl animate-fade-up">
        <p class="text-sm font-medium text-primary tracking-widest uppercase mb-4">
          Software Engineer
        </p>
        <h1 class="heading-display text-4xl md:text-5xl lg:text-6xl mb-6 leading-[1.15]">
          Building things for the web, writing about the journey.
        </h1>
        <p class="text-lg text-muted-foreground leading-relaxed mb-8">
          I'm Irham - a frontend engineer focused on design systems,
          smooth user experiences, and bringing value to the products I work on. I share what I learn along the way.
        </p>
        <div class="flex gap-3">
          <a
            href="/blog"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-primary text-primary-foreground font-medium text-sm hover:opacity-90 transition-opacity"
          >
            Read the blog
          </a>
          <a
            href="/projects"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-secondary text-foreground font-medium text-sm hover:bg-secondary/80 transition-colors"
          >
            View projects
          </a>
        </div>
      </div>
    </section>

    <section class="container pb-20">
      <SectionHeading client:idle title="Recent Posts" linkTo="/blog" />
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {recentPosts.map((post, i) => (
          <BlogCard client:idle post={post.data} id={post.id} index={i} />
        ))}
        {recentPosts.length === 0 && (
          <p class="text-center text-muted-foreground col-span-full">
            No posts to show yet. Check back later!
          </p>
        )}
      </div>
    </section>

    <section class="container pb-20">
      <SectionHeading client:idle title="Featured Projects" linkTo="/projects" />
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {featuredProjects.map((project, i) => (
          <ProjectCard client:idle project={project.data} id={project.id} index={i} />
        ))}
        {featuredProjects.length === 0 && (
          <p class="text-center text-muted-foreground col-span-full">
            No projects to show yet. Check back later!
          </p>
        )}
      </div>
    </section>
  </main>
</BaseLayout>

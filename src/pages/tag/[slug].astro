---
import { getCollection } from 'astro:content';
import BlogCard from '../../components/react/BlogCard.tsx';
import ProjectCard from '../../components/react/ProjectCard.tsx';
import SectionHeading from '../../components/react/SectionHeading.tsx';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { ArrowLeft } from 'lucide-react';

export async function getStaticPaths() {
	const blogPosts = await getCollection('blog');
	const projects = await getCollection('projects');

	const allTags = new Set<string>();
	blogPosts.forEach(post => post.data.tags.forEach(tag => allTags.add(tag)));
	projects.forEach(project => project.data.tags.forEach(tag => allTags.add(tag)));

	return Array.from(allTags).map((tag) => ({
		params: { slug: tag },
		props: { tag },
	}));
}

type Props = {
	tag: string;
};

const { tag } = Astro.props;

const blogPosts = (await getCollection('blog')).filter(post =>
	post.data.tags.includes(tag)
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const projects = (await getCollection('projects')).filter(project =>
	project.data.tags.includes(tag)
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout>
	<main class="flex-1">
		<section class="container py-16">
			<a
				href="/tag"
				class="animate-fade-up inline-flex items-center gap-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors mb-8"
			>
				<ArrowLeft className="w-4 h-4" />
				Back to tags
			</a>
			<div class="max-w-2xl animate-fade-up">
				<h1 class="heading-display text-3xl md:text-4xl mb-3">Tag: {tag}</h1>
				<p class="text-muted-foreground">
					Contents tagged with "{tag}".
				</p>
			</div>
		</section>

		{blogPosts.length > 0 && (
			<section class="container pb-20">
				<SectionHeading client:idle title="Blog Posts" />
				<div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
					{blogPosts.map((post, i) => (
						<BlogCard client:idle post={post.data} id={post.id} index={i} />
					))}
				</div>
			</section>
		)}

		{projects.length > 0 && (
			<section class="container pb-20">
				<SectionHeading client:idle title="Projects" />
				<div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
					{projects.map((project, i) => (
						<ProjectCard client:idle project={project.data} id={project.id} index={i} />
					))}
				</div>
			</section>
		)}

		{blogPosts.length === 0 && projects.length === 0 && (
			<section class="container pb-20">
				<p class="text-muted-foreground">No content found for this tag.</p>
			</section>
		)}
	</main>
</BaseLayout>
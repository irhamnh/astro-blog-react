---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/react/Footer.tsx';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/react/Header.tsx';
import { ArrowLeft } from 'lucide-react';


type Props = CollectionEntry<'blog'>['data'];
const { pathname } = Astro.url;
const { title, description, pubDate, heroImage, readTime, tags } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body>
		<Header client:load pathname={pathname}/>
			<main class="blog-post flex-1">
        {/* hero Image */}
        <div class="w-full h-64 md:h-80 relative overflow-hidden">
          {heroImage && <Image src={heroImage} alt={title} class="w-full h-full object-cover" />}
          {!heroImage && <div class="w-full h-full bg-gradient-to-br from-primary/20 via-accent/10 to-secondary"></div>}
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_50%,hsl(var(--primary)/0.15),transparent_70%)]"></div>
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_80%_20%,hsl(var(--accent)/0.1),transparent_60%)]"></div>
        </div>

        <article class="container max-w-3xl py-12 animate-fade-up">
          <a
            href="/blog"
            class="inline-flex items-center gap-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors mb-8"
          >
            <ArrowLeft className="w-4 h-4" />
            Back to blog
				</a>
          <div class="flex items-center gap-2 text-sm text-muted-foreground mb-4">
						<FormattedDate date={pubDate} />
            <span class="w-1 h-1 rounded-full bg-muted-foreground/40" />
            <span>{readTime}</span>
          </div>

          <h1 class="heading-display text-3xl md:text-4xl lg:text-5xl mb-6 leading-tight">
            {title}
          </h1>
          <div class="flex flex-wrap gap-2 mb-10">
            {tags.map((tag) => (
              <a href={`/tag/${encodeURIComponent(tag)}`}>
                <span class="tag-pill">{tag}</span>
              </a>
            ))}
          </div>

					<slot></slot>
        </article>
      </main>
		<Footer />
	</body>
</html>
